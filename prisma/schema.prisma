
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TmdbCache {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  response  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime @default(now())
}

model ApiLog {
  id        Int      @id @default(autoincrement())
  url       String
  title     String?
  type      String?
  source    String?
  hit       Boolean
  ip        String?
  ua        String?
  createdAt DateTime @default(now())
}
